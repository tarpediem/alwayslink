<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Light-touch override of sale.report_saleorder_document.
        Adds a styled title block, customer card, signature & terms sections.
        The SCSS catches everything via the .als-report wrapper from
        external_layout_als (no ancestor class needed here).
    -->
    <template id="report_saleorder_document_als"
              inherit_id="sale.report_saleorder_document">

        <!-- Suppress the standard address/title rendering: we draw our own. -->
        <xpath expr="//t[@t-set='address']" position="replace">
            <t t-set="address"/>
        </xpath>
        <xpath expr="//t[@t-set='layout_document_title']" position="replace">
            <t t-set="layout_document_title"/>
        </xpath>

        <!-- Title block: prepend a styled doc header before the meta row. -->
        <xpath expr="//div[@id='informations']" position="before">
            <div class="als-report__title-block">
                <div class="als-report__title-row">
                    <div class="als-report__title-doc">
                        <div class="als-report__doc-kind">
                            <t t-if="env.context.get('proforma', False) or is_pro_forma">Pro-Forma Invoice</t>
                            <t t-elif="doc.state in ['draft','sent']">Quotation</t>
                            <t t-else="">Sales Order</t>
                        </div>
                        <div class="als-report__doc-number">
                            <span t-field="doc.name">S00001</span>
                        </div>
                        <div class="als-report__doc-validity text-muted"
                             t-if="doc.validity_date and doc.state in ['draft','sent']">
                            Valid until <span t-field="doc.validity_date"/>
                        </div>
                    </div>
                    <div class="als-report__title-customer">
                        <div class="als-report__customer-label">Bill to</div>
                        <div class="als-report__customer-body">
                            <strong t-field="doc.partner_id.name"/>
                            <div t-field="doc.partner_id"
                                 t-options='{"widget": "contact", "fields": ["address", "phone"], "no_marker": True, "phone_icons": False}'/>
                            <div t-if="doc.partner_id.vat" class="text-muted small">
                                <t t-if="doc.company_id.account_fiscal_country_id.vat_label"
                                   t-out="doc.company_id.account_fiscal_country_id.vat_label"/>
                                <t t-else="">Tax ID</t>:
                                <span t-field="doc.partner_id.vat"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>

        <!-- Wrap the meta row with our class so SCSS picks it up. -->
        <xpath expr="//div[@id='informations']" position="attributes">
            <attribute name="class" add="als-report__meta" separator=" "/>
        </xpath>

        <!-- Style the line table. -->
        <xpath expr="//table[contains(@class, 'o_main_table')]" position="attributes">
            <attribute name="class" add="als-report__lines" separator=" "/>
        </xpath>

        <!-- Append signature block (when required) and terms block at the end of the page. -->
        <xpath expr="//div[@class='page']" position="inside">
            <div class="als-report__signature"
                 t-if="doc.require_signature">
                <div class="als-report__signature-col">
                    <div class="als-report__signature-label">For Always Link Solutions</div>
                    <div class="als-report__signature-line"/>
                    <div class="als-report__signature-name"
                         t-if="doc.company_id.als_signatory_name">
                        <span t-field="doc.company_id.als_signatory_name"/>
                    </div>
                    <div class="als-report__signature-title text-muted"
                         t-if="doc.company_id.als_signatory_title">
                        <span t-field="doc.company_id.als_signatory_title"/>
                    </div>
                </div>
                <div class="als-report__signature-col">
                    <div class="als-report__signature-label">For Customer</div>
                    <div class="als-report__signature-line"/>
                    <div class="als-report__signature-name">
                        <span t-field="doc.partner_id.name"/>
                    </div>
                    <div class="als-report__signature-title text-muted">
                        Date: ___________________
                    </div>
                </div>
            </div>

            <div class="als-report__terms" t-if="doc.note">
                <div class="als-report__terms-title">Terms &amp; Conditions</div>
                <div class="als-report__terms-body">
                    <span t-field="doc.note"/>
                </div>
            </div>

            <div class="als-report__terms" t-if="doc.payment_term_id and doc.payment_term_id.note">
                <div class="als-report__terms-title">Payment Terms</div>
                <div class="als-report__terms-body">
                    <span t-field="doc.payment_term_id.note"/>
                </div>
            </div>
        </xpath>

    </template>
</odoo>
