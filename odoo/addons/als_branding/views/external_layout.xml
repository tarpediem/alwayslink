<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        ALS branded external layout.
        Selectable in Settings > Companies > Document Layout.
        Wraps every printable Odoo document with the ALS brand identity.

        Notes on layout strategy:
        - The wkhtmltopdf <div class="header"> / <div class="footer">
          render in separate HTML documents where Bootstrap grid + flexbox
          rendering is unreliable. So we keep these slots minimal (small
          repeating logo / single-line legal note) and ship the brand
          identity inside <div class="article"> via the .als-report__brand
          block at the top, which uses our SCSS bundle reliably.
    -->
    <template id="external_layout_als" name="ALS — Always Link">

        <div t-attf-class="header o_company_#{company.id}_layout als-report__pageheader">
            <!-- Page header: minimal repeating identifier for multi-page docs.
                 No cyan line here — that lives on the body brand block only,
                 to avoid the double-band visual at the top of page 1. -->
            <div style="text-align: right; font-family: Helvetica, Arial, sans-serif; font-size: 7.5pt; color: #9CA3AB; padding-top: 4px;">
                <span t-field="company.name"/>
            </div>
        </div>

        <div t-attf-class="article o_report_layout_als als-report o_company_#{company.id}_layout"
             t-att-data-oe-model="o and o._name"
             t-att-data-oe-id="o and o.id"
             t-att-data-oe-lang="o and o.env.context.get('lang')">

            <div class="als-report__brand">
                <div class="als-report__brand-row">
                    <div class="als-report__brand-logo">
                        <img t-if="company.logo"
                             t-att-src="image_data_uri(company.logo)"
                             alt="Logo"/>
                    </div>
                    <div class="als-report__brand-info">
                        <div class="als-report__brand-contact">
                            <span t-if="company.email" t-field="company.email"/>
                            <span t-if="company.phone"> · <span t-field="company.phone"/></span>
                            <span t-if="company.website"> · <span t-field="company.website"/></span>
                        </div>
                        <div t-if="company.vat" class="als-report__brand-vat">
                            <t t-out="company.country_id.vat_label or 'Tax ID'"/>:
                            <span t-field="company.vat"/>
                        </div>
                    </div>
                </div>
            </div>

            <t t-call="web.address_layout"/>
            <h2 t-if="layout_document_title" t-out="layout_document_title" class="als-report__layout-title"/>
            <t t-out="0"/>
        </div>

        <div t-attf-class="footer o_company_#{company.id}_layout als-report__pagefooter">
            <table style="width: 100%; border-collapse: collapse; font-family: Helvetica, Arial, sans-serif; font-size: 7.5pt; color: #6B737B; border-top: 2px solid #0F1D31;">
                <tr>
                    <td style="vertical-align: top; padding: 6px 0; text-align: left; width: 33%;">
                        <strong style="color: #0F1D31; font-size: 7.5pt; text-transform: uppercase; letter-spacing: 0.1em;">Always Link Solutions</strong><br/>
                        <span t-field="company.partner_id"
                              t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                    </td>
                    <td style="vertical-align: top; padding: 6px 0; text-align: center; width: 34%;">
                        <strong style="color: #0F1D31; font-size: 7.5pt; text-transform: uppercase; letter-spacing: 0.1em;">Contact</strong><br/>
                        <span t-if="company.website" t-field="company.website"/><br/>
                        <span t-if="company.email" t-field="company.email"/><br/>
                        <span t-if="company.phone" t-field="company.phone"/>
                    </td>
                    <td style="vertical-align: top; padding: 6px 0; text-align: right; width: 33%;">
                        <strong style="color: #0F1D31; font-size: 7.5pt; text-transform: uppercase; letter-spacing: 0.1em;">Banking</strong><br/>
                        <span t-if="company.als_bank_info" t-field="company.als_bank_info" style="white-space: pre-line;"/>
                        <em t-if="not company.als_bank_info">Available on request</em>
                    </td>
                </tr>
                <tr>
                    <td colspan="3" style="border-top: 1px solid #E5E7EB; padding-top: 4px; font-size: 7pt; color: #9CA3AB;">
                        <span style="float: left;">
                            <span t-if="report_type == 'pdf'">
                                Page <span class="page"/> / <span class="topage"/>
                            </span>
                        </span>
                        <span style="float: right;" t-if="company.report_footer">
                            <span t-field="company.report_footer"/>
                        </span>
                    </td>
                </tr>
            </table>
        </div>

    </template>
</odoo>
